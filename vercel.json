{
  "version": 2,
  "builds": [
    {
      "src": "skills/search/main.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb" }
    },
    {
      "src": "dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "skills/search/main.py" },
    { "src": "/(.*)", "dest": "dist/$1" }
  ]
}
